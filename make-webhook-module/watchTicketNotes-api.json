{
  "url": "https://webservices5.autotask.net/ATServicesRest/V1.0/TicketNoteWebhooks",
  "method": "POST",
  "headers": {
    "ApiIntegrationCode": "{{connection.integrationCode}}",
    "UserName": "{{connection.username}}",
    "Secret": "{{connection.secret}}",
    "Content-Type": "application/json"
  },
  "body": {
    "name": "Make Webhook - {{hook.name}}",
    "webhookUrl": "{{hook.address}}",
    "deactivationUrl": "{{hook.address}}",
    "secretKey": "{{hook.secretKey}}",
    "isActive": true,
    "sendThresholdExceededNotification": false,
    "isSubscribedToCreateEvents": "{{if(contains(eventTypes; \"create\"); true; if(length(eventTypes) = 0; true; false))}}",
    "isSubscribedToUpdateEvents": "{{if(contains(eventTypes; \"update\"); true; if(length(eventTypes) = 0; true; false))}}",
    "isSubscribedToDeleteEvents": "{{if(contains(eventTypes; \"delete\"); true; if(length(eventTypes) = 0; true; false))}}"
  },
  "response": {
    "webhookId": "{{body.itemId}}"
  },
  "cleanup": {
    "url": "https://webservices5.autotask.net/ATServicesRest/V1.0/TicketNoteWebhooks/{{webhookId}}",
    "method": "DELETE",
    "headers": {
      "ApiIntegrationCode": "{{connection.integrationCode}}",
      "UserName": "{{connection.username}}",
      "Secret": "{{connection.secret}}"
    }
  }
}